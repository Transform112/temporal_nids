[
  {
    "common_name": "duration",
    "cic17_source": "Flow Duration",
    "unsw_source": "dur",
    "transform": "cic17_us_to_sec",
    "notes": "CIC17 Flow Duration is \u00b5s, UNSW dur is seconds",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "protocol",
    "cic17_source": "Protocol",
    "unsw_source": "proto",
    "transform": "shared_categorical",
    "notes": "CIC17 uses IANA numbers, UNSW uses text labels (tcp/udp/...) -- map to shared encoding",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "fwd_packets",
    "cic17_source": "Total Fwd Packets",
    "unsw_source": "Spkts",
    "transform": "passthrough",
    "notes": "Source->dest direction packets",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "bwd_packets",
    "cic17_source": "Total Backward Packets",
    "unsw_source": "Dpkts",
    "transform": "passthrough",
    "notes": "Dest->source direction packets",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "fwd_bytes",
    "cic17_source": "Total Length of Fwd Packets",
    "unsw_source": "sbytes",
    "transform": "passthrough",
    "notes": "Source->dest bytes",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "bwd_bytes",
    "cic17_source": "Total Length of Bwd Packets",
    "unsw_source": "dbytes",
    "transform": "passthrough",
    "notes": "Dest->source bytes",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "byte_rate",
    "cic17_source": "Flow Bytes/s",
    "unsw_source": "DERIVED",
    "transform": "cic17_inf_to_zero; unsw_derive_sload_dload_avg",
    "notes": "CIC17 Flow Bytes/s has Inf (->0). UNSW: use (Sload+Dload)/2 as byte rate proxy",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "packet_rate",
    "cic17_source": "Flow Packets/s",
    "unsw_source": "DERIVED",
    "transform": "cic17_inf_to_zero; unsw_derive_spkts_div_dur",
    "notes": "UNSW raw has no 'rate' col (train/test only). Derive as Spkts/dur for raw.",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "mean_iat",
    "cic17_source": "Flow IAT Mean",
    "unsw_source": "DERIVED",
    "transform": "unsw_avg_sintpkt_dintpkt",
    "notes": "UNSW splits IAT by direction; average the two to match CIC17's combined mean",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "std_iat",
    "cic17_source": "Flow IAT Std",
    "unsw_source": "DERIVED",
    "transform": "unsw_avg_sjit_djit",
    "notes": "Jitter \u2260 std(IAT); flagged as approximation in paper. DROPPED: jitter proxy is wrong signal, not just different \u2014 actively harmful for cross-dataset training.",
    "is_imputed": false,
    "verified": true,
    "mismatch": null,
    "dropped": true
  },
  {
    "common_name": "mean_pkt_len",
    "cic17_source": "Average Packet Size",
    "unsw_source": "DERIVED",
    "transform": "unsw_avg_smeansz_dmeansz",
    "notes": "Average of source and destination mean packet sizes",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "syn_count",
    "cic17_source": "SYN Flag Count",
    "unsw_source": "DERIVED",
    "transform": "impute_zero_and_flag",
    "notes": "SYN flag count not available in UNSW-NB15 -- impute 0 + is_imputed flag. DROPPED: constant 0 for UNSW = dataset-identity signal (leakage).",
    "is_imputed": true,
    "verified": true,
    "mismatch": null,
    "dropped": true
  },
  {
    "common_name": "ack_count",
    "cic17_source": "ACK Flag Count",
    "unsw_source": "DERIVED",
    "transform": "impute_zero_and_flag",
    "notes": "ACK flag count not available in UNSW-NB15 -- impute 0 + is_imputed flag. DROPPED: constant 0 for UNSW = dataset-identity signal (leakage).",
    "is_imputed": true,
    "verified": true,
    "mismatch": null,
    "dropped": true
  },
  {
    "common_name": "init_win_fwd",
    "cic17_source": "Init_Win_bytes_forward",
    "unsw_source": "swin",
    "transform": "passthrough",
    "notes": "TCP window advertisement -- source direction",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "init_win_bwd",
    "cic17_source": "Init_Win_bytes_backward",
    "unsw_source": "dwin",
    "transform": "passthrough",
    "notes": "TCP window advertisement -- destination direction",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "down_up_ratio",
    "cic17_source": "Down/Up Ratio",
    "unsw_source": "DERIVED",
    "transform": "derive_dbytes_div_sbytes; guard_div_zero",
    "notes": "Guard divide-by-zero: if sbytes=0 -> 0.0",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  },
  {
    "common_name": "state_summary",
    "cic17_source": "DERIVED",
    "unsw_source": "state",
    "transform": "onehot_shared_buckets",
    "notes": "UNSW state field is closest analogue. One-hot with 'unknown' bucket for unseen values.",
    "is_imputed": false,
    "verified": true,
    "mismatch": null
  }
]